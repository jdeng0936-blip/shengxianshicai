# ========================================
# 鲜标智投 — 生鲜食材配送投标文件智能生成平台
# 后端环境变量配置模板
# 复制此文件为 .env 并填写实际值：cp .env.example .env
# ========================================

# --- 应用配置 ---
APP_NAME="鲜标智投 — 生鲜食材配送投标文件智能生成平台"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY="change-me-to-a-random-secret-key-at-least-32-chars"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- 数据库 (PostgreSQL 16 + pgvector) ---
# Docker 内部使用 pgvector 镜像，全新生鲜专用库（禁止连回煤矿 sri_v2）
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5435/fresh_bid_platform"

# --- Redis Stack ---
REDIS_URL="redis://localhost:6380/0"

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# =====================================================
# AI / LLM 配置 (从 .env copy 提取可用通道)
# =====================================================

# --- LiteLLM 代理网关（用于统一路由访问大模型，例如 Gemini） ---
LITELLM_BASE_URL="https://litellm.ailingxi.net/v1"
# 如果你的代码将 LITELLM 作为 OpenAI 兼容接口，请填写：
OPENAI_API_KEY="sk-xxx" 
OPENAI_BASE_URL="https://litellm.ailingxi.net/v1"
AI_MODEL="gpt-5.4"

# --- 阿里云 DashScope (千问 / BGE 向量生成) ---
QWEN_API_KEY="sk-xxx"
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# =====================================================
# 阿里云 OSS (复用已有 Bucket)
# =====================================================
OSS_ENDPOINT="oss-rg-china-mainland.aliyuncs.com"
OSS_ACCESS_KEY_ID="你的阿里云AccessKeyID"
OSS_ACCESS_KEY_SECRET="你的阿里云AccessKeySecret"
OSS_BUCKET_NAME="your-bucket-name"

# =====================================================
# LibreOffice (Word -> PDF 转换)
# =====================================================
SOFFICE_PATH="C:\Program Files\LibreOffice\program\soffice.exe"

# =====================================================
# 投标业务配置
# =====================================================
QUOTATION_MIN_DISCOUNT=0.05
QUOTATION_MAX_DISCOUNT=0.15
CREDENTIAL_EXPIRY_WARN_DAYS=90
ADMIN_INIT_PASSWORD="admin123"
